# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration
DATABASE_TYPE=sqlite  # sqlite, postgresql, csv
DATABASE_URL=sqlite:///./bi_dashboard.db
# For PostgreSQL (uncomment and modify if using PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/bi_dashboard

# Server Configuration
DEBUG=True
HOST=0.0.0.0
PORT=8000

# CSV Data Storage (if using CSV)
CSV_DATA_PATH=./data/
